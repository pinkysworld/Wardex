  "route_completion_policy": {
    "new_runtime_route_requires": [
      "OpenAPI path metadata with x-wardex-auth and a route-domain owner, or an explicit internal_runtime_routes/internal_runtime_route_prefixes entry",
      "SDK or admin-console helper coverage before operator-facing routes are considered complete",
      "focused tests when the route changes auth, tenancy, destructive action, persistence, or release proof behavior"
    ],
    "exception_policy": "internal_runtime_routes and internal_runtime_route_prefixes are compatibility/internal exceptions only; promote operator-facing exceptions into OpenAPI before calling them stable public API."
  },
