{
  "schema_version": 1,
  "canonical_product_name": "Wardex",
  "purpose": "Architecture manifest for API contract ownership and AppState decomposition decisions.",
  "contract_decisions": {
    "version_source": "Cargo.toml package.version remains the release/version source of truth.",
    "auth_source": "src/server_routing.rs classifies runtime route access; OpenAPI and docs must consume or validate the same classes.",
    "route_owner_source": "This manifest owns bounded-context route prefixes until a Rust route manifest replaces supplemental endpoint catalogs.",
    "schema_source_target": "The next spine step is a Rust manifest that emits OpenAPI operations, auth metadata, route owners, SDK parity checks, and frontend helper contracts.",
    "openapi_public_policy": "Public OpenAPI exposure is explicit; production can require authentication unless server.openapi_public or WARDEX_OPENAPI_PUBLIC allows it.",
    "sdk_policy": "Python, TypeScript, and admin-console helpers must expose stable wrappers for operator-facing routes before a route is considered complete."
  },
  "auth_classes": [
    "public",
    "agent",
    "cluster",
    "authenticated"
  ],
  "route_domains": [
    {
      "id": "platform_identity",
      "owner": "server-platform",
      "description": "Identity, RBAC, static platform metadata, API discovery, and administrative configuration.",
      "route_prefixes": [
        "/api/admin",
        "/api/auth",
        "/api/config",
        "/api/docs",
