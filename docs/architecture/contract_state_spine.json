  "state_decisions": {
    "current_boundary": "AppState remains a compatibility shell during v1.0.x hardening.",
    "next_boundary": "Move fields into domain-owned state shards with one lock per shard after contract-owner parity is enforced.",
    "migration_order": [
      "platform_identity",
      "fleet_control",
      "telemetry_connectors",
      "soc_operations",
      "detection_intelligence",
      "governance_reliability"
    ],
    "lock_policy": "New hot-path handlers should use domain labels with tracked_lock and avoid adding unlabelled state.lock() callsites.",
    "route_policy": "Every new OpenAPI path must match exactly one route domain prefix and carry x-wardex-auth metadata.",
    "release_slo": {
      "state_lock_poisoned_total": "must remain 0 during concurrent_smoke and release acceptance",
      "state_lock_wait_observability": "wardex_state_lock_wait_seconds_max and wardex_state_lock_wait_seconds_total must remain exported for hot-route contention triage",
      "failed_auth_lockout_metrics": "failed_auth_lockout must prove threshold, breach, and reset metrics before release"
    }
  },
